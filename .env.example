# =============================================================
# INEXCI FRONTEND — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# =============================================================

# ===================================
# API
# ===================================
# URL pública do backend (sem barra final).
NEXT_PUBLIC_API_URL=http://localhost:3002

# ===================================
# Landing page URLs
# =================================== 
# Em dev local, aponte para localhost. Em produção, use os domínios reais.
NEXT_PUBLIC_SITE_URL=https://inexci.com.br
NEXT_PUBLIC_APP_URL=https://app.inexci.com.br
